{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Security Engineering Intelligence Platform",
  "version": "0.2.0",
  "identifier": "com.tonythetaylor.securityengineeringplatform",
  "build": {
    "beforeDevCommand": "npx http-server web -p 8080",
    "devUrl": "http://localhost:8080",
    "frontendDist": "../web"
  },
  "app": {
    "windows": [
      {
        "title": "Security Engineering Intelligence Platform",
        "width": 1440,
        "height": 950,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ]
  }
}